rules_version = '2';

// 家計簿アプリ Firestore セキュリティルール
// データはすべて users/{uid}/... 配下に保存される
//  - users/{uid}/months/{key}     … 月ごとの取引
//  - users/{uid}/meta/assets      … 投資資産
//  - users/{uid}/meta/accounts    … 口座
// 「ログインしている本人(uid一致)」だけが自分のデータを読み書きできる。
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
